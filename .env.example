
# Groq API key for the agent's single LLM call. Free keys: https://console.groq.com/keys
# OPTIONAL: The bundled demo replays recorded runs with no key. Only required to record new traces.
GROQ_API_KEY=

# Optional: override the default agent model
# CASSETTE_AGENT_MODEL=llama-3.3-70b-versatile

# --- Supabase (failure-library store — Layer 2) ---
# Required to write/query diagnosed failure entries.
# Create a free project at https://supabase.com, then copy Project URL and anon key.
# Run the DDL in trace_store/failure_library.py once in the Supabase SQL editor.
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<your-anon-or-service-role-key>
